# ══════════════════════════════════════════════════════════════════
# RemitAgent — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit your .env file.
# ══════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────
# CORE
# ──────────────────────────────────────────────────────────────────
NODE_ENV=development          # production | development
PORT=3000

# ──────────────────────────────────────────────────────────────────
# TELEGRAM BOT
# How to get: Open Telegram → message @BotFather → /newbot
# Copy the "HTTP API token" it gives you.
# ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # e.g. 7912345678:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Railway deployment URL (set after first Railway deploy)
# Leave empty during local development — polling mode will be used instead.
WEBHOOK_URL=                  # e.g. https://remit-agent-production.up.railway.app

# ──────────────────────────────────────────────────────────────────
# WDK — Tether Wallet Development Kit
# How to get seed phrase:
#   Option A: Run `node -e "import('@tetherto/wdk').then(m => console.log(m.default.getRandomSeedPhrase()))"`
#   Option B: Use any BIP-39 generator (e.g. https://iancoleman.io/bip39/)
#   ⚠️  NEVER share or commit this phrase. It controls ALL user wallets.
# ──────────────────────────────────────────────────────────────────
MASTER_SEED_PHRASE=           # e.g. word1 word2 word3 ... word12
WDK_SEED=                     # Same as MASTER_SEED_PHRASE (used by MCP server)

# WDK Indexer API Key (enables balance + history queries)
# How to get: Register at https://docs.wallet.tether.io → developer portal
WDK_INDEXER_API_KEY=

# ──────────────────────────────────────────────────────────────────
# TRON (primary chain — cheapest USDt transfers)
# How to get TronGrid API key: https://www.trongrid.io/ → sign up → Create API Key
# ──────────────────────────────────────────────────────────────────
TRONGRID_API_KEY=

# ──────────────────────────────────────────────────────────────────
# ARBITRUM / EVM (secondary chain — gasless ERC-4337)
# Free public RPC — no key needed for basic use:
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Candide (ERC-4337 bundler + paymaster for gasless transactions)
# How to get: https://candide.dev → create account → create app → copy URLs
CANDIDE_BUNDLER_URL=          # e.g. https://api.candide.dev/bundler/v3/arbitrum/YOUR_KEY
CANDIDE_PAYMASTER_URL=        # e.g. https://api.candide.dev/paymaster/v3/arbitrum/YOUR_KEY

# ──────────────────────────────────────────────────────────────────
# AI — Google Gemini (NLP parser)
# How to get: https://aistudio.google.com/ → "Get API key" → Create API key
# Free tier: 15 requests/min, 1M tokens/day — more than enough for hackathon
# ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=               # e.g. AIzaSy...

# ──────────────────────────────────────────────────────────────────
# DATABASE
# Railway sets these automatically when you add Postgres + Redis plugins.
# For local development, install Postgres + Redis locally or use Docker:
#   docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres
#   docker run -d -p 6379:6379 redis
# ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remit_agent
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────────
# RATE APIS
# ──────────────────────────────────────────────────────────────────

# CoinGecko (USDT price data) — optional, works without key at 30 req/min
# How to get: https://www.coingecko.com/en/api → "Get Your API Key"
COINGECKO_API_KEY=

# Open Exchange Rates (fiat/fiat conversion e.g. GBP → USD)
# How to get: https://openexchangerates.org/ → sign up → copy App ID
# Free tier: 1000 req/month
OPENEXCHANGERATES_APP_ID=

# Yellowcard (African market rates — NGN, KES, GHS, ZAR, etc.)
# How to get: https://yellowcard.io/developers → apply for API access
# (optional — only needed for African corridors)
YELLOWCARD_API_KEY=

# ──────────────────────────────────────────────────────────────────
# ON-RAMP — MoonPay (fiat → USDt via card)
# How to get: https://www.moonpay.com/ → "For Businesses" → apply
# Test keys available immediately in sandbox mode
# ──────────────────────────────────────────────────────────────────
MOONPAY_API_KEY=              # pk_test_... (test) or pk_live_... (production)
MOONPAY_SECRET_KEY=           # sk_test_... (test) or sk_live_... (production)
