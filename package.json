{
  "name": "remit-agent",
  "version": "1.0.0",
  "description": "AI-powered cross-border remittances using Tether WDK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tetherto/wdk": "latest",
    "@tetherto/wdk-protocol-fiat-moonpay": "latest",
    "@tetherto/wdk-wallet-evm": "latest",
    "@tetherto/wdk-wallet-evm-erc-4337": "latest",
    "@tetherto/wdk-wallet-tron-gasfree": "latest",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
